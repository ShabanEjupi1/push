<?xml version='1.0' encoding='UTF-8'?>
<faces-config version="2.0"
              xmlns="http://java.sun.com/xml/ns/javaee" 
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
              xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-facesconfig_2_0.xsd">
    <application>
        <resource-bundle>
            <base-name>mk.com.snt.kc.warehouse.messages</base-name>
            <var>msgs</var>
        </resource-bundle>
        <locale-config>
            <default-locale>en</default-locale>
            <supported-locale>sq</supported-locale>
            <supported-locale>sr</supported-locale>
        </locale-config>
        <resource-handler>mk.com.snt.kc.warehouse.view.util.CustomResourceHandler</resource-handler>
    </application>
    <factory>
        <exception-handler-factory>mk.com.snt.kc.warehouse.view.util.ApplicationExceptionHandlingFactory</exception-handler-factory>
    </factory>
    <lifecycle>
        <phase-listener>com.ocpsoft.pretty.faces.event.MultiPageMessagesSupport</phase-listener>
    </lifecycle>
</faces-config>
